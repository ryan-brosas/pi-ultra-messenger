{
  "name": "pi-ultra-messenger",
  "version": "0.26.0",
  "description": "Swarm-first multi-agent messaging and task orchestration extension for Pi",
  "type": "module",
  "author": "Ryan Brosas <https://github.com/ryan-brosas>",
  "contributors": [
    "Tom X Nguyen <https://github.com/monotykamary>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryan-brosas/pi-ultra-messenger.git"
  },
  "homepage": "https://github.com/ryan-brosas/pi-ultra-messenger#readme",
  "bugs": {
    "url": "https://github.com/ryan-brosas/pi-ultra-messenger/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "swarm",
    "multi-agent",
    "agent-mesh",
    "task-orchestration",
    "subagents",
    "cli"
  ],
  "bin": {
    "pi-ultra-messenger": "dist/harness/cli.js"
  },
  "files": [
    "*.ts",
    "*.mjs",
    "dist/**",
    "agents/**",
    "handlers/**",
    "overlay/**",
    "store/**",
    "extension/**",
    "swarm/**",
    "harness/**",
    "migrations/**",
    "skills/**",
    "docs/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:dead": "knip --no-gitignore",
    "release": "standard-version",
    "release:push": "bash scripts/release.sh",
    "release:dry-run": "standard-version --dry-run",
    "postinstall": "simple-git-hooks 2>/dev/null || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck && npm run test",
    "commit-msg": "npx commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "knip": "6.14.1",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "standard-version": "9.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "overrides": {
    "brace-expansion": "5.0.6"
  },
  "packageManager": "pnpm@11.6.0"
}
